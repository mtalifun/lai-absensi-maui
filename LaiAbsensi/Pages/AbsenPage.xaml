<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LaiAbsensi.Pages.AbsenPage"
             Title="Absen">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label x:Name="lblWelcome" FontSize="22" FontAttributes="Bold"/>
        <Label x:Name="lblStatus" Text="Siap absen" />
        <Button x:Name="btnMasuk" Text="Absen Masuk" Clicked="OnMasukClicked" BackgroundColor="Green" TextColor="White"/>
        <Button x:Name="btnPulang" Text="Absen Pulang" Clicked="OnPulangClicked" BackgroundColor="DarkRed" TextColor="White"/>
    </VerticalStackLayout>
</ContentPage>