<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="LaiAbsensi.MainPage" BackgroundColor="#fff7ed">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">
            <Image Source="leaf_logo.png" HeightRequest="80" HorizontalOptions="Center"/>
            <Label Text="LAI Absensi" FontSize="28" FontAttributes="Bold" TextColor="#ea580c" HorizontalOptions="Center"/>
            <Border x:Name="loginFrame" Padding="20" StrokeShape="RoundRectangle 16" BackgroundColor="White" Stroke="#fed7aa">
                <VerticalStackLayout Spacing="10">
                    <Entry x:Name="txtEmail" Placeholder="Email" Keyboard="Email"/>
                    <Entry x:Name="txtPass" Placeholder="Password" IsPassword="True"/>
                    <Button Text="Login" Clicked="OnLogin" BackgroundColor="#ea580c" TextColor="White"/>
                    <Button Text="Daftar" Clicked="OnRegister" BackgroundColor="#64748b" TextColor="White"/>
                </VerticalStackLayout>
            </Border>
            <Border x:Name="appFrame" IsVisible="False" Padding="20" StrokeShape="RoundRectangle 16" BackgroundColor="White" Stroke="#fed7aa">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="lblUser" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label x:Name="lblStatus" Text="Belum absen hari ini" BackgroundColor="#ffedd5" Padding="10" HorizontalTextAlignment="Center"/>
                    <Button Text="📸 CLOCK IN" Clicked="OnClockIn" BackgroundColor="#16a34a" TextColor="White" HeightRequest="50"/>
                    <Button Text="📸 CLOCK OUT" Clicked="OnClockOut" BackgroundColor="#dc2626" TextColor="White" HeightRequest="50"/>
                    <Button Text="Logout" Clicked="OnLogout" BackgroundColor="#e2e8f0" TextColor="#334155"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
