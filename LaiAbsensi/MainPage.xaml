<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui/xaml"
             x:Class="LaiAbsensi.MainPage"
             BackgroundColor="#eef2ff">
  <ScrollView>
    <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">
      
      <Label Text="📍 LAI Absensi" 
             FontSize="28" 
             FontAttributes="Bold" 
             TextColor="#1e3a8a" 
             HorizontalOptions="Center"/>
      
      <!-- LOGIN FRAME -->
      <Frame x:Name="loginFrame" Padding="20" CornerRadius="16" BackgroundColor="White" HasShadow="True">
        <VerticalStackLayout Spacing="12">
          <Entry x:Name="txtEmail" Placeholder="Email kantor" Keyboard="Email" />
          <Entry x:Name="txtPass" Placeholder="Password" IsPassword="True" />
          <Button Text="Login" Clicked="OnLogin" BackgroundColor="#2563eb" TextColor="White" CornerRadius="8"/>
          <Button Text="Daftar Akun Baru" Clicked="OnRegister" BackgroundColor="#64748b" TextColor="White" CornerRadius="8"/>
        </VerticalStackLayout>
      </Frame>

      <!-- APP FRAME -->
      <Frame x:Name="appFrame" IsVisible="False" Padding="20" CornerRadius="16" BackgroundColor="White" HasShadow="True">
        <VerticalStackLayout Spacing="12">
          <Label x:Name="lblUser" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center" TextColor="#334155"/>
          <Label x:Name="lblStatus" Text="Belum absen hari ini" BackgroundColor="#dbeafe" TextColor="#1e40af" Padding="10" HorizontalTextAlignment="Center"/>
          <Button Text="📸 CLOCK IN" Clicked="OnClockIn" BackgroundColor="#16a34a" TextColor="White" HeightRequest="55" FontAttributes="Bold"/>
          <Button Text="📸 CLOCK OUT" Clicked="OnClockOut" BackgroundColor="#ea580c" TextColor="White" HeightRequest="55" FontAttributes="Bold"/>
          <Button Text="Logout" Clicked="OnLogout" BackgroundColor="#e2e8f0" TextColor="#334155"/>
        </VerticalStackLayout>
      </Frame>

    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
