<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LaiAbsensi.MainPage"
             BackgroundColor="#eef2ff">
    
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">
            
            <Label Text="📍 LAI Absensi" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#1e3a8a" 
                   HorizontalOptions="Center"/>
      
            <Frame x:Name="loginFrame" 
                   Padding="20" 
                   CornerRadius="16" 
                   BackgroundColor="White"
                   HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Entry x:Name="txtEmail" 
                           Placeholder="Email" 
                           Keyboard="Email"/>
                    <Entry x:Name="txtPass" 
                           Placeholder="Password" 
                           IsPassword="True"/>
                    <Button Text="Login" 
                            Clicked="OnLogin" 
                            BackgroundColor="#2563eb" 
                            TextColor="White"/>
                    <Button Text="Daftar Akun Baru" 
                            Clicked="OnRegister" 
                            BackgroundColor="#64748b" 
                            TextColor="White"/>
                </VerticalStackLayout>
            </Frame>

            <Frame x:Name="appFrame" 
                   IsVisible="False" 
                   Padding="20" 
                   CornerRadius="16" 
                   BackgroundColor="White"
                   HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="lblUser" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center"/>
                    <Label x:Name="lblStatus" 
                           Text="Belum absen hari ini" 
                           BackgroundColor="#dbeafe" 
                           Padding="10" 
                           HorizontalTextAlignment="Center"/>
                    <Button Text="📸 CLOCK IN" 
                            Clicked="OnClockIn" 
                            BackgroundColor="#16a34a" 
                            TextColor="White" 
                            HeightRequest="50"/>
                    <Button Text="📸 CLOCK OUT" 
                            Clicked="OnClockOut" 
                            BackgroundColor="#ea580c" 
                            TextColor="White" 
                            HeightRequest="50"/>
                    <Button Text="Logout" 
                            Clicked="OnLogout" 
                            BackgroundColor="#e2e8f0" 
                            TextColor="#334155"/>
                </VerticalStackLayout>
            </Frame>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
