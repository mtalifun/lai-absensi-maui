<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="LaiAbsensi.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:LaiAbsensi.Pages"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent Title="Absen" ContentTemplate="{DataTemplate pages:AbsenPage}" Route="absen" />
        <ShellContent Title="Riwayat" ContentTemplate="{DataTemplate pages:HistoryPage}" Route="history" />
        <ShellContent Title="Setting" ContentTemplate="{DataTemplate pages:SettingsPage}" Route="settings" />
    </TabBar>
</Shell>